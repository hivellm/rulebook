# EditorConfig — https://editorconfig.org
# Standardizes file-ending format across editors. Mirrors .gitattributes:
# LF everywhere + final newline, Windows-only scripts keep CRLF.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Shell scripts: refuse to run with CRLF — always LF.
[*.sh]
end_of_line = lf

# Windows-only scripts must keep CRLF.
[*.{bat,cmd,ps1}]
end_of_line = crlf

# Markdown uses trailing whitespace for hard line breaks.
[*.md]
trim_trailing_whitespace = false

# Makefiles require tabs.
[Makefile]
indent_style = tab
